        <name>Hamilton</name>
        <description>Day 1 — Waterfront Trail through Burlington</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -79.7633,43.3832,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>St. Catharines</name>
        <description>Day 1 — Through Niagara wine country</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -79.2469,43.1594,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Batavia</name>
        <description>Day 2 — Midway Buffalo to Rochester</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -78.1876,43.002,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Geneva</name>
        <description>Day 3 — Finger Lakes, good lunch stop</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -77.0445,43.0797,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Amsterdam</name>
        <description>Day 6 — Mohawk Valley, rolling hills begin</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -74.5688,42.942,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Schenectady</name>
        <description>Day 6 — Last major town before Albany</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.9396,42.8142,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Hudson</name>
        <description>Day 7 — Empire State Trail, 36mi paved from Albany</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.791,42.2529,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Rhinebeck</name>
        <description>Day 7 — Scenic Hudson Valley town</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.901,41.9409,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Walkway Over the Hudson</name>
        <description>Day 7 — Iconic converted rail bridge. A highlight of the trip.</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.943,41.714,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Beacon</name>
        <description>Day 8 — Good coffee stop, Hudson Valley</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.984,41.5048,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Peekskill</name>
        <description>Day 8 — Traffic picks up from here south</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.8934,41.29,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Tarrytown</name>
        <description>Day 8 — Westchester, last stretch before NYC</description>
        <styleUrl>#icon-1899-DB4436</styleUrl>
        <Point>
          <coordinates>
            -73.8685,41.0534,0
          </coordinates>
        </Point>
      </Placemark>
    </Folder>
